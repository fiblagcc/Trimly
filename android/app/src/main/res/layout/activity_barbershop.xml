<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sand">

    <!-- Hero -->
    <FrameLayout
        android:id="@+id/hero"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@color/primary_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/backBtn"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="top|start"
            android:layout_margin="14dp"
            app:cardBackgroundColor="#33000000"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_left"
                app:tint="#FFFFFF"/>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/favBtn"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="top|end"
            android:layout_margin="14dp"
            app:cardBackgroundColor="#33000000"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_heart"
                app:tint="#FFFFFF"/>

        </androidx.cardview.widget.CardView>

        <FrameLayout
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_hero_avatar">

            <TextView
                android:id="@+id/heroEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✂️"
                android:textSize="42sp"/>

        </FrameLayout>

    </FrameLayout>

    <!-- Sheet -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/hero"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_sheet_top"
            android:paddingTop="24dp"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/shopName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Barbershop"
                app:fontFamily="@font/fraunces_semibold"
                android:textColor="@color/ink"
                android:textSize="24sp"/>

            <TextView
                android:id="@+id/shopAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/ink_muted"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/ratingBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ New"
                    android:textColor="@color/badge_pending_text"
                    android:textSize="12sp"
                    android:background="@drawable/bg_badge_star"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/statusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Closed"
                    android:textColor="@color/badge_active_text"
                    android:textSize="12sp"
                    android:background="@drawable/bg_badge_open"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginLeft="8dp"/>

            </LinearLayout>

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <TextView
                    android:id="@+id/tabServices"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="Services"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_cat_active"/>

                <TextView
                    android:id="@+id/tabReviews"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="Reviews"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/ink_muted"
                    android:background="@drawable/bg_cat_inactive"
                    android:layout_marginLeft="8dp"/>

                <TextView
                    android:id="@+id/tabAbout"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="About"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/ink_muted"
                    android:background="@drawable/bg_cat_inactive"
                    android:layout_marginLeft="8dp"/>

            </LinearLayout>

            <!-- Tab content -->
            <LinearLayout
                android:id="@+id/contentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
