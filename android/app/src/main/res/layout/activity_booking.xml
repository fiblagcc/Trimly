<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sand">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/backBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/primary"/>

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book Appointment"
            app:fontFamily="@font/fraunces_semibold"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:layout_marginLeft="12dp"/>

    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="32dp">

            <!-- Barber / shop info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@color/badge_active_bg"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="✂️"
                        android:textSize="22sp"/>

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginLeft="10dp">

                    <TextView
                        android:id="@+id/barberName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Barber"
                        android:textColor="@color/ink"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/shopName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Barbershop"
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Service label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT SERVICE"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <!-- Services -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:id="@+id/serviceFade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_service_active"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fade" android:textColor="@color/primary" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$25" android:textColor="@color/primary" android:textSize="10sp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/serviceBeard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cat_inactive"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:layout_marginLeft="6dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Beard Trim" android:textColor="@color/ink_muted" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$15" android:textColor="@color/ink_muted" android:textSize="10sp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/serviceFullCut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cat_inactive"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:layout_marginLeft="6dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full Cut" android:textColor="@color/ink_muted" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$35" android:textColor="@color/ink_muted" android:textSize="10sp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/serviceLineup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cat_inactive"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:layout_marginLeft="6dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lineup" android:textColor="@color/ink_muted" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$20" android:textColor="@color/ink_muted" android:textSize="10sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Select date label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT DATE"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <!-- Month header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView android:id="@+id/calPrev" android:layout_width="44dp" android:layout_height="36dp" android:text="‹" android:textColor="@color/primary" android:textSize="22sp" android:gravity="center"/>
                <TextView android:id="@+id/calMonthLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Month" android:textColor="@color/ink" android:textSize="15sp" android:gravity="center" app:fontFamily="@font/fraunces_semibold"/>
                <TextView android:id="@+id/calNext" android:layout_width="44dp" android:layout_height="36dp" android:text="›" android:textColor="@color/primary" android:textSize="22sp" android:gravity="center"/>

            </LinearLayout>

            <!-- Day labels -->
            <LinearLayout
                android:id="@+id/dayLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Su" android:textColor="@color/ink_faint" android:textSize="11sp" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mo" android:textColor="@color/ink_faint" android:textSize="11sp" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tu" android:textColor="@color/ink_faint" android:textSize="11sp" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="We" android:textColor="@color/ink_faint" android:textSize="11sp" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Th" android:textColor="@color/ink_faint" android:textSize="11sp" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fr" android:textColor="@color/ink_faint" android:textSize="11sp" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sa" android:textColor="@color/ink_faint" android:textSize="11sp" android:gravity="center"/>

            </LinearLayout>

            <!-- Calendar rows (populated dynamically) -->
            <LinearLayout android:id="@+id/calRow1" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/calRow2" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/calRow3" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/calRow4" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/calRow5" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
                <TextView android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:textColor="@color/ink"/>
            </LinearLayout>

            <!-- Time label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AVAILABLE TIMES"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <!-- Times row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView android:id="@+id/time1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/ink_muted" android:textSize="12sp" android:background="@drawable/bg_cat_inactive" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="7dp" android:paddingBottom="7dp"/>
                <TextView android:id="@+id/time2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/ink_muted" android:textSize="12sp" android:background="@drawable/bg_cat_inactive" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_marginLeft="6dp"/>
                <TextView android:id="@+id/time3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/ink_muted" android:textSize="12sp" android:background="@drawable/bg_cat_inactive" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_marginLeft="6dp"/>
                <TextView android:id="@+id/time4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/ink_muted" android:textSize="12sp" android:background="@drawable/bg_cat_inactive" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_marginLeft="6dp"/>

            </LinearLayout>

            <!-- Times row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView android:id="@+id/time5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/ink_muted" android:textSize="12sp" android:background="@drawable/bg_cat_inactive" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="7dp" android:paddingBottom="7dp"/>
                <TextView android:id="@+id/time6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/ink_muted" android:textSize="12sp" android:background="@drawable/bg_cat_inactive" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_marginLeft="6dp"/>
                <TextView android:id="@+id/time7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/ink_muted" android:textSize="12sp" android:background="@drawable/bg_cat_inactive" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_marginLeft="6dp"/>
                <TextView android:id="@+id/time8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/ink_muted" android:textSize="12sp" android:background="@drawable/bg_cat_inactive" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_marginLeft="6dp"/>

            </LinearLayout>

            <!-- No slots message -->
            <TextView
                android:id="@+id/noSlotsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No open slots right now. Check back soon."
                android:textColor="@color/ink_muted"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"
                android:visibility="gone"/>

            <!-- Summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Service" android:textColor="@color/ink_muted" android:textSize="11sp"/>
                    <TextView android:id="@+id/summaryService" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fade" android:textColor="@color/ink" android:textSize="13sp" android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date &amp; Time" android:textColor="@color/ink_muted" android:textSize="11sp"/>
                    <TextView android:id="@+id/summaryDateTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pick a time" android:textColor="@color/ink" android:textSize="13sp" android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Confirm button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/confirmBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Confirm Booking"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
