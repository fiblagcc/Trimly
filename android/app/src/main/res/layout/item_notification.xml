<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp">

    <View
        android:id="@+id/notifUnreadDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_notif_dot"
        android:layout_marginEnd="10dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notifTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/notifBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/ink_muted"
            android:textSize="13sp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/notifTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/ink_faint"
            android:textSize="11sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</LinearLayout>
