<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- Botón volver -->
            <TextView
                android:id="@+id/backToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ←Login"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:layout_marginBottom="16dp"/>

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trimly"
                app:fontFamily="@font/fraunces_semibold"
                android:textColor="@color/primary_dark"
                android:textSize="26sp"
                android:layout_gravity="center"
                android:letterSpacing="-0.02"/>

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CREATE ACCOUNT"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_gravity="center"
                android:layout_marginBottom="28dp"/>

            <!-- Role Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_toggle"
                android:padding="4dp"
                android:layout_marginBottom="22dp">

                <Button
                    android:id="@+id/btnClient"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Client"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="8dp"/>

                <Button
                    android:id="@+id/btnBarber"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Barber"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink_muted"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="8dp"/>

            </LinearLayout>

            <!-- Label Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FULL NAME"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <!-- Campo Full Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="@color/surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="@color/outline"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/fullNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="John Doe"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink_faint"
                    android:textSize="15sp"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Label Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <!-- Campo Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="@color/surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="@color/outline"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_mail"
                app:startIconTint="@color/primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="john@email.com"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink_faint"
                    android:textSize="15sp"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Label Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHONE"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <!-- Campo Phone -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="@color/surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="@color/outline"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_phone"
                app:startIconTint="@color/primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/phoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="+1 (555) 000-0000"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink_faint"
                    android:textSize="15sp"
                    android:inputType="phone"
                    android:paddingHorizontal="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Label Username -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USERNAME"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <!-- Campo Username -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="@color/surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="@color/outline"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/usernameInput"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="username"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink_faint"
                    android:textSize="15sp"
                    android:paddingHorizontal="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Label Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <!-- Campo Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:boxBackgroundColor="@color/surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="@color/outline"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/primary"
                app:passwordToggleEnabled="true"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink_faint"
                    android:textSize="15sp"
                    android:paddingHorizontal="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botón Register -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/registerBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Create Account"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textColor="@color/ink"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/loginText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login"
                    android:textColor="@color/primary"
                    android:textSize="13sp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>