<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/sand">

    <!-- Hero -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_onboarding_hero">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="Trimly"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trimly"
                app:fontFamily="@font/fraunces_semibold"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:letterSpacing="0.04"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Bottom content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="28dp"
        android:paddingRight="28dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Barber shop\nnear you"
            app:fontFamily="@font/fraunces_semibold"
            android:textColor="@color/ink"
            android:textSize="32sp"
            android:lineSpacingMultiplier="1.05"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Find a barber near you, book online, and skip the wait."
            android:textColor="@color/ink_muted"
            android:textSize="15sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/getStartedBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Get Started"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp"/>

        <TextView
            android:id="@+id/onboardSignIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I already have an account"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="16dp"/>

    </LinearLayout>

</LinearLayout>
